{
  "name": "api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    "./types": "./src/types.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "hono": "^4.7.7",
    "pg": "^8.20.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^3.1.1",
    "prisma": "^7.8.0",
    "tsx": "^4.19.3",
    "typescript": "^6.0.3",
    "vitest": "^3.1.1"
  }
}
